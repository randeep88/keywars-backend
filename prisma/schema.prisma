generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  username   String      @unique
  email      String      @unique
  createdAt  String
  updatedAt  String
  firstName  String
  fullName   String
  imageUrl   String
  lastName   String
  clerkId    String      @unique
  playerWars PlayerWar[]
}

model War {
  id        String      @id @default(cuid())
  roomId    String
  startedAt String
  status    String
  passage   String
  players   PlayerWar[]
}

model PlayerWar {
  id         String   @id @default(cuid())
  userId     String
  warId      String
  timeTaken  Int
  finishedAt String
  accuracy   Int
  error      Int
  progress   Int
  roomId     String
  wpm        Int
  isWinner   Boolean  @default(false)
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  war        War      @relation(fields: [warId], references: [id])
}
