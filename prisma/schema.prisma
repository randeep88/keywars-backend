generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  clerkId    String      @unique
  fullName   String
  firstName  String
  lastName   String
  username   String      @unique
  email      String      @unique
  imageUrl   String
  createdAt  String
  updatedAt  String
  playerWars PlayerWar[]
}

model War {
  id        String      @id @default(cuid())
  roomId    String
  startedAt String
  status    String
  players   PlayerWar[]
  passage   String
}

model PlayerWar {
  id         String @id @default(cuid())
  warId      String
  userId     String
  roomId     String
  wpm        Int
  accuracy   Int
  error      Int
  progress   Int
  finishedAt String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  rank     Int?
  isWinner Boolean @default(false)

  war  War  @relation(fields: [warId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
