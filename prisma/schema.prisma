generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String
  email     String   @unique
  password  String
  photo     String?  @default("https://i.pinimg.com/736x/13/74/20/137420f5b9c39bc911e472f5d20f053e.jpg")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model War {
  id        String      @id @default(cuid())
  roomId    String      @unique
  startedAt String
  status    String
  players   PlayerWar[]
  passage   String
}

model PlayerWar {
  id                String  @id @default(cuid())
  userId            String
  warId             String
  totalKeystrokes   Int
  correctKeystrokes Int
  finished          Boolean @default(false)
  finishedAt        String

  war War @relation(fields: [warId], references: [id])
}
