generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  name       String
  username   String
  email      String      @unique
  password   String
  photo      String?     @default("https://i.pinimg.com/736x/13/74/20/137420f5b9c39bc911e472f5d20f053e.jpg")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  playerWars PlayerWar[]
}

model War {
  id        String      @id @default(cuid())
  roomId    String
  startedAt String
  status    String
  players   PlayerWar[]
  passage   String
}

model PlayerWar {
  id         String @id @default(cuid())
  warId      String
  userId     String
  roomId     String
  wpm        Int
  accuracy   Int
  error      Int
  progress   Int
  finishedAt String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  rank     Int?
  isWinner Boolean @default(false)

  war  War  @relation(fields: [warId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
